<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dim_background">

    <!-- Dim background click dismiss handle -->
    <View
        android:id="@+id/viewDismissDim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true" />

    <!-- Dialog Header Title -->
    <TextView
        android:id="@+id/tvScannerDialogTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="Scan Ticket QR Code"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/cardScannerContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Centered Card holding the camera preview -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardScannerContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="16dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintWidth_percent="0.65"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Camera BarcodeView -->
            <com.journeyapps.barcodescanner.BarcodeView
                android:id="@+id/dialogBarcodeScanner"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- Frame outline overlay border -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/scanner_border_overlay" />

            <!-- Scanning laser line -->
            <View
                android:id="@+id/viewScannerLaser"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="@color/primary"
                android:visibility="visible" />
        </FrameLayout>
    </androidx.cardview.widget.CardView>

    <!-- Close button floating in top-right corner of scanner card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/btnDismissScanner"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        app:cardCornerRadius="19dp"
        app:cardElevation="20dp"
        app:cardBackgroundColor="#CC000000"
        app:layout_constraintEnd_toEndOf="@id/cardScannerContainer"
        app:layout_constraintTop_toTopOf="@id/cardScannerContainer">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="✕"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold" />
    </androidx.cardview.widget.CardView>

    <!-- Instruction Subtitle below scanner -->
    <TextView
        android:id="@+id/tvScannerDialogInstruction"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        android:text="Align the QR code on the ticket inside the square frame to verify automatically"
        android:textColor="#CCffffff"
        android:textSize="13sp"
        android:gravity="center"
        android:lineSpacingExtra="3dp"
        app:layout_constraintTop_toBottomOf="@id/cardScannerContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
