<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dim_background">

    <!-- Dim background click dismiss -->
    <View
        android:id="@+id/viewDismissDimResult"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true" />

    <!-- Center Card container -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardResultContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="16dp"
        app:cardBackgroundColor="@color/white"
        app:layout_constraintWidth_percent="0.85"
        app:layout_constraintHeight_percent="0.9"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fillViewport="true"
                android:clipToPadding="false"
                android:overScrollMode="never">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:gravity="center_horizontal">

                    <!-- Status Icon/Logo Container (No circle background) -->
                    <FrameLayout
                        android:id="@+id/layoutStatusIconContainer"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:id="@+id/ivStatusLogo"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="fitCenter"
                            android:src="@drawable/app_logo"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/tvStatusIndicatorEmoji"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="V"
                            android:textColor="@color/foreground"
                            android:textSize="56sp"
                            android:visibility="visible" />
                    </FrameLayout>

                    <!-- Verification Title -->
                    <TextView
                        android:id="@+id/tvValidationTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Valid QR Code"
                        android:textColor="@color/primary"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <!-- Verification Subtitle -->
                    <TextView
                        android:id="@+id/tvValidationSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="16dp"
                        android:text="Entry Authorized"
                        android:textColor="@color/muted"
                        android:textSize="13sp"
                        android:gravity="center" />

                    <!-- Attendee Details Card Container -->
                    <LinearLayout
                        android:id="@+id/layoutAttendeeDetails"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@color/gray_light"
                        android:padding="16dp"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TICKET INFO"
                            android:textColor="@color/muted"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"
                            android:layout_marginBottom="8dp" />

                        <!-- Booking ID -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="6dp">
                            <TextView
                                android:layout_width="80dp"
                                android:layout_height="wrap_content"
                                android:text="Booking ID"
                                android:textColor="@color/muted"
                                android:textSize="12sp" />
                            <TextView
                                android:id="@+id/tvValBookingId"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="EVT-2026-XXXXXX"
                                android:textColor="@color/foreground"
                                android:textStyle="bold"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <!-- Attendee Name -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="6dp">
                            <TextView
                                android:layout_width="80dp"
                                android:layout_height="wrap_content"
                                android:text="Attendee"
                                android:textColor="@color/muted"
                                android:textSize="12sp" />
                            <TextView
                                android:id="@+id/tvValAttendeeName"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="John Doe"
                                android:textColor="@color/foreground"
                                android:textStyle="bold"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <!-- Phone -->
                        <LinearLayout
                            android:id="@+id/layoutPhoneRow"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="6dp"
                            android:visibility="gone">
                            <TextView
                                android:layout_width="80dp"
                                android:layout_height="wrap_content"
                                android:text="Phone"
                                android:textColor="@color/muted"
                                android:textSize="12sp" />
                            <TextView
                                android:id="@+id/tvValPhone"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="9876543210"
                                android:textColor="@color/foreground"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <!-- Event -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="6dp">
                            <TextView
                                android:layout_width="80dp"
                                android:layout_height="wrap_content"
                                android:text="Event"
                                android:textColor="@color/muted"
                                android:textSize="12sp" />
                            <TextView
                                android:id="@+id/tvValSeminar"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Event"
                                android:textColor="@color/foreground"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <!-- Venue -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="6dp">
                            <TextView
                                android:layout_width="80dp"
                                android:layout_height="wrap_content"
                                android:text="Venue"
                                android:textColor="@color/muted"
                                android:textSize="12sp" />
                            <TextView
                                android:id="@+id/tvValVenue"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Venue"
                                android:textColor="@color/foreground"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <!-- Date & Time -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="6dp">
                            <TextView
                                android:layout_width="80dp"
                                android:layout_height="wrap_content"
                                android:text="Date &amp; Time"
                                android:textColor="@color/muted"
                                android:textSize="12sp" />
                            <TextView
                                android:id="@+id/tvValDate"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Date &amp; Time"
                                android:textColor="@color/foreground"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <!-- Seats -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="6dp">
                            <TextView
                                android:layout_width="80dp"
                                android:layout_height="wrap_content"
                                android:text="Seats"
                                android:textColor="@color/muted"
                                android:textSize="12sp" />
                            <TextView
                                android:id="@+id/tvValSeats"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="A10, A11"
                                android:textColor="@color/foreground"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <!-- Divider -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/gray_divider"
                            android:layout_marginTop="8dp"
                            android:layout_marginBottom="8dp" />

                        <!-- Total Paid -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <TextView
                                android:layout_width="80dp"
                                android:layout_height="wrap_content"
                                android:text="Amount Paid"
                                android:textColor="@color/muted"
                                android:textSize="12sp" />
                            <TextView
                                android:id="@+id/tvValPrice"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Rs. 1,500"
                                android:textColor="@color/primary"
                                android:textStyle="bold"
                                android:textSize="14sp" />
                        </LinearLayout>

                    </LinearLayout>

                    <!-- Attendee approval list -->
                    <LinearLayout
                        android:id="@+id/layoutAttendeeSection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@color/gray_light"
                        android:padding="16dp"
                        android:layout_marginBottom="16dp"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="6dp"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/tvAttendeeSectionTitle"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="ATTENDEE APPROVALS"
                                android:textColor="@color/foreground"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.08" />

                            <TextView
                                android:id="@+id/tvAttendeeSectionSummary"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 approved"
                                android:textColor="@color/primary"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvAttendeeSectionHint"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:text="Tick the checkbox on the right for each attendee who has arrived."
                            android:textColor="@color/muted"
                            android:textSize="12sp"
                            android:lineSpacingExtra="2dp" />

                        <LinearLayout
                            android:id="@+id/layoutAttendeeList"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />
                    </LinearLayout>

                    <!-- Error panel (visible for invalid state) -->
                    <LinearLayout
                        android:id="@+id/layoutErrorReason"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@color/danger_bg"
                        android:padding="16dp"
                        android:layout_marginBottom="16dp"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/tvErrorReasonHeader"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="REJECTION DETAILS"
                            android:textColor="@color/danger"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvErrorReasonText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="This ticket was rejected or not found."
                            android:textColor="@color/foreground"
                            android:textSize="12sp"
                            android:lineSpacingExtra="3dp" />

                    </LinearLayout>

                </LinearLayout>
            </ScrollView>

            <!-- Close Button -->
            <TextView
                android:id="@+id/btnDismissResult"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/btn_gradient_bg"
                android:text="Done"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>




